<script>
document.addEventListener('DOMContentLoaded', function() {
    const microphoneBtn = document.getElementById('microphoneBtn');
    const descriptionField = document.getElementById('{{ form.Description.vars.id }}');
    const recordingStatus = document.getElementById('recordingStatus');
    
    // Vérifier si l'API Web Speech est disponible dans le navigateur
    if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        const recognition = new SpeechRecognition();
        
        recognition.lang = 'fr-FR'; // Français
        recognition.continuous = true; // Reconnaissance continue
        recognition.interimResults = true; // Résultats intermédiaires
        
        let finalTranscript = '';
        let isRecording = false;
        let recordingTimer = null;
        
        microphoneBtn.addEventListener('click', function() {
            if (!isRecording) {
                // Commencer l'enregistrement
                finalTranscript = '';
                isRecording = true;
                
                // Changer l'apparence du bouton et afficher le statut
                microphoneBtn.innerHTML = '<i class="fas fa-stop"></i>';
                microphoneBtn.classList.add('text-danger');
                recordingStatus.style.display = 'block';
                
                // Démarrer la reconnaissance vocale
                recognition.start();
                
                // Définir une durée maximale d'enregistrement (30 secondes par exemple)
                recordingTimer = setTimeout(function() {
                    if (isRecording) {
                        recognition.stop();
                    }
                }, 30000); // 30 secondes
            } else {
                // Arrêter l'enregistrement manuellement
                isRecording = false;
                clearTimeout(recordingTimer);
                recognition.stop();
            }
        });
        
        recognition.onresult = function(event) {
            let interimTranscript = '';
            
            // Recueillir tous les résultats
            for (let i = event.resultIndex; i < event.results.length; i++) {
                const transcript = event.results[i][0].transcript;
                
                if (event.results[i].isFinal) {
                    finalTranscript += transcript + ' ';
                } else {
                    interimTranscript += transcript;
                }
            }
            
            // Ne pas mettre à jour le champ pendant l'enregistrement
            // Les résultats seront ajoutés à la fin de l'enregistrement
        };
        
        recognition.onend = function() {
            // Appliquer le texte transcrit et corrigé au champ une fois l'enregistrement terminé
            if (isRecording) {
                // Si l'enregistrement s'est arrêté automatiquement (pas par l'utilisateur)
                isRecording = false;
                clearTimeout(recordingTimer);
            }
            
            // Appliquer des corrections basiques (première lettre en majuscule, points à la fin des phrases)
            let correctedText = finalTranscript.trim();
            
            // Mettre la première lettre en majuscule
            if (correctedText.length > 0) {
                correctedText = correctedText.charAt(0).toUpperCase() + correctedText.slice(1);
            }
            
            // Ajouter un point à la fin si nécessaire
            if (correctedText.length > 0 && !['.', '!', '?'].includes(correctedText.charAt(correctedText.length - 1))) {
                correctedText += '.';
            }
            
            // Ajouter le texte corrigé au champ
            if (descriptionField.value) {
                descriptionField.value += ' ' + correctedText;
            } else {
                descriptionField.value = correctedText;
            }
            
            // Réinitialiser l'interface
            microphoneBtn.innerHTML = '<i class="fas fa-microphone"></i>';
            microphoneBtn.classList.remove('text-danger');
            recordingStatus.style.display = 'none';
        };
        
        recognition.onerror = function(event) {
            console.error('Erreur de reconnaissance vocale:', event.error);
            isRecording = false;
            clearTimeout(recordingTimer);
            
            // Réinitialiser l'interface
            microphoneBtn.innerHTML = '<i class="fas fa-microphone"></i>';
            microphoneBtn.classList.remove('text-danger');
            recordingStatus.style.display = 'none';
        };
    } else {
        // Cacher le bouton si l'API n'est pas supportée
        microphoneBtn.style.display = 'none';
        console.warn("L'API Web Speech n'est pas supportée par ce navigateur.");
    }
});
</script>
