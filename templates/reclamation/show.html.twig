{% block body%}          
 <br><br>
 <br><br>
<div class="table-container">
      
      <br><br>

 <h2 class="">
 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 
 &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 
 
 Liste de réclamations  de Mr  {{app.session.get('user_nom')}} {{app.session.get('user_prenom')}}
 </h2>

 <br><br>
 <br><br>
 <table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Prenom</th>
                    <th>Email</th>
                    <th>Numero Telephone</th>
                    <th>Description</th>
                    <th>Type</th>
                    <th>Image</th>
                     <th>Status</th>
                      <th>Reponse</th>
                    <th>Actions</th>
                </tr>
                {% for us in reclamations %}
<tr>

<td>{{ us.getUserNom }}</td>
<td>{{ us.getUserPrenom()}}</td>
<td>
{{ us.getUserEmail() }}</td>
<td>{{ us.getUsertel()}}</td>
<td>{{ us.getDescription() }}</td>
<td>{{ us.getType()}}</td>

<td>
<img class="rounded-circle1 me-lg-2" src="{{ asset('uploads/' ~ us.getImage()) }}" alt="Image" >

</td>
<td>{{ us.getStatus() }}</td>
{%   if us.getReponseTexte()    is null    %}
<td>      Pas de Réponse      </td>

{%   else  %}


<td>{{ us.getReponseTexte() }}</td>
{%    endif  %}
<td>   
 
{% if us.getStatus() == "En cours" %}

                        <a href="/reclamation/{{us.id}}/edit/{{app.session.get('id')}}" > &nbsp;&nbsp;
                
                        <span class="action-btn edit"><i class="bi bi-pencil-fill"></i></span></a>  &nbsp;&nbsp;
                        {% endif  %}
                    <a href="/reclamation/{{us.id}}/remove" >    <span class="action-btn trash"><i class="bi bi-trash-fill"></i></span> </a>
                    </td>
</tr>

{% endfor %}
</table><br>
<br>
<br>
<div class="d-flex justify-content-center">
    <a href="/reclamation/create/{{app.session.get('id')}}" class="text-center text-decoration-none">
        <span class="d-flex flex-column align-items-center">
            <i class="bi bi-file-earmark-text me-2 fs-1"></i>
            <span>Add Reclamation</span>
        </span>
    </a>
</div>


