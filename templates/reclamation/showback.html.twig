{% extends 'base.html.twig' %}

{% block body %}

            <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.3/jquery.min.js"></script>
    <script>
      $(document).ready(function () {
        $("#myInput").on("keyup", function () {
          var value = $(this).val().toLowerCase();
          var visibleRows = 0;

          $("#myTable tbody tr").each(function () {
            if ($(this).text().toLowerCase().indexOf(value) > -1) {
              $(this).show();
              visibleRows++;
            } else {
              $(this).hide();
            }
          });

          // Afficher le message "Aucun résultat" si nécessaire
          if (visibleRows === 0) {
            $("#noResults").show();
          } else {
            $("#noResults").hide();
          }
        });
      });
    </script>





    <div class="table-container">
    <!-- Assurez-vous d'inclure Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

<a href="{{ path('showallreclamationbacktechnique') }}" class="btn btn-warning mb-3">
    <i class="bi bi-search"></i> Problème Technique
</a>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
<a href="{{ path('showallreclamationresercation') }}" class="btn btn-warning mb-3">
    <i class="bi bi-search"></i> Problème Réservation
</a>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
<a href="{{ path('showallPaiement') }}" class="btn btn-warning mb-3">
    <i class="bi bi-search"></i> Problème Paiement
</a>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
