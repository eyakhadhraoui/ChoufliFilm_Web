<script>
document.addEventListener('DOMContentLoaded', function() {
    const notificationDropdown = document.getElementById('notificationDropdown');
    const notificationBadge = document.getElementById('notificationBadge');
    
    notificationDropdown.addEventListener('click', function() {
        // Supprimer le badge
        if (notificationBadge) {
            notificationBadge.remove();
        }

        // Mettre à jour les notifications
        fetch('{{ path("mark_notifications_read") }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Retirer la classe unread-notification de toutes les notifications
                document.querySelectorAll('.unread-notification').forEach(notification => {
                    notification.classList.remove('unread-notification');
                });
                
                // Log pour debug
                console.log('Notifications mises à jour avec succès');
            } else {
                console.error('Erreur lors de la mise à jour des notifications');
            }
        })
        .catch(error => {
            console.error('Erreur:', error);
        });
    });
});
</script>
