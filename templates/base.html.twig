<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Store the current notification count to detect changes
        let currentNotificationCount = {{ notificationRepository.findBy({'type': 'user'})|length }};
        let currentUnreadCount = {{ notificationRepository.findBy({'type': 'user', 'isRead': false})|length }};
        
        // Function to poll for notifications using the current page
        function checkForNewNotifications() {
            // Use the Fetch API to get the current page content
            fetch(window.location.href)
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    
                    // Extract notification data from the fetched page
                    const newUnreadCount = doc.getElementById('notificationBadge').textContent.trim();
                    
                    // If there are new notifications, update the UI
                    if (parseInt(newUnreadCount) > currentUnreadCount) {
                        // Update badge
                        document.getElementById('notificationBadge').textContent = newUnreadCount;
                        
                        // Replace notification container content
                        const newContainer = doc.getElementById('notificationContainer').innerHTML;
                        document.getElementById('notificationContainer').innerHTML = newContainer;
                        
                        // Play notification sound (optional)
                        playNotificationSound();
                        
                        // Update current counts
                        currentUnreadCount = parseInt(newUnreadCount);
                    }
                })
                .catch(error => console.error('Error checking for notifications:', error));
        }
        
        // Function to play notification sound
        function playNotificationSound() {
            // You'll need to add an audio file to your project for this to work
            // const sound = new Audio('/path/to/notification-sound.mp3');
            // sound.play();
            console.log('New notification received!');
        }
        
        // Mark notifications as read when clicked
        function setupNotificationClicks() {
            document.querySelectorAll('.unread-notification').forEach(notification => {
                notification.addEventListener('click', function() {
                    const notificationId = this.dataset.notificationId;
                    
                    // This is a placeholder for an AJAX call
                    // In a real implementation, you would send an AJAX request to mark as read
                    this.classList.remove('unread-notification');
                    
                    // Update the unread count
                    const badge = document.getElementById('notificationBadge');
                    let count = parseInt(badge.textContent) - 1;
                    if (count <= 0) {
                        badge.style.display = 'none';
                        badge.textContent = '0';
                    } else {
                        badge.textContent = count.toString();
                    }
                    
                    currentUnreadCount = count;
                    
                    // In a real implementation you would make an AJAX call like:
                    /*
                    fetch('/mark-notification-read/' + notificationId, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    */
                });
            });
        }
        
        // Set up click events for existing notifications
        setupNotificationClicks();
        
        // Check for new notifications periodically (every 30 seconds)
        setInterval(checkForNewNotifications, 30000);
        
        // You can also check when the user becomes active again after being away
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden) {
                checkForNewNotifications();
            }
        });
    });
</script>
