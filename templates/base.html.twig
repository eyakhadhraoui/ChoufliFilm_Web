        .action-btn.edit { color: #2196f3; }   /* Bleu */
        .action-btn.trash { color: #f44336; }  /* Rouge */

/* Ajout minimal de styles pour le comportement de défilement */
.navbar.navbar-expand {
    transition: transform 0.3s ease;
}

.navbar.navbar-expand.hidden {
    transform: translateY(-100%);
}

/* Ajout d'un conteneur pour grouper les liens */
.nav-group {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.notification-icon-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
}

.notification-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: #ff4444;
    color: white;
    border-radius: 50%;
    padding: 4px 8px;
    font-size: 12px;
    min-width: 20px;
    height: 20px;
