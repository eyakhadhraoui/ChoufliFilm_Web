{% block body %}
<br><br><br><br>
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="section-title text-center text-primary px-3">Shopping Cart</h6>
            <h1 class="mb-5">My Reservations</h1>
        </div>
        
        {% if reservations is empty %}
            <div class="text-center">
                <div class="mb-4">
                    <i class="fa fa-shopping-cart fa-4x text-primary mb-3"></i>
                    <h3>Your cart is empty</h3>
                    <p class="text-muted">Browse our movies and make a reservation!</p>
                </div>
                <a href="{{ path('showallfilm') }}" class="btn btn-primary py-3 px-5">Browse Movies</a>
            </div>
        {% else %}
            <div class="row">
                <div class="col-12">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="bg-primary text-white">
                                <tr>
                                    <th>Movie</th>
                                    <th>Date</th>
                                    <th>Cinema</th>
                                    <th>Association</th>
                                    <th>Seat Type</th>
                                    <th>Number of Seats</th>
                                    <th>Price per Seat</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for reservation in reservations %}
                                    <tr>
                                        <td>{{ reservation.titre }}</td>
                                        <td>{{ reservation.dateReservation ? reservation.dateReservation|date('Y-m-d') : '' }}</td>
                                        <td>{{ reservation.salle ? reservation.salle.nomSalle : 'N/A' }}</td>
                                        <td>{{ reservation.association ? reservation.association.nom : 'N/A' }}</td>
                                        <td>{{ reservation.typePlace }}</td>
                                        <td>{{ reservation.nombrePlaces }}</td>
                                        <td>
                                            {% if reservation.typePlace == 'VIP' %}
                                                15 DT
                                            {% else %}
                                                10 DT
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if reservation.typePlace == 'VIP' %}
                                                {{ reservation.nombrePlaces * 15 }} DT
                                            {% else %}
                                                {{ reservation.nombrePlaces * 10 }} DT
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if reservation.status == 'pending' %}
                                                <span class="badge bg-warning">Pending</span>
                                            {% else %}
                                                <span class="badge bg-success">Paid</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if reservation.status == 'pending' %}
                                                <a href="{{ path('app_payment', {'id': reservation.id}) }}" 
                                                   class="btn btn-sm btn-primary">
                                                    Pay Now
                                                </a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td colspan="7" class="text-end"><strong>Cart Total:</strong></td>
                                    <td colspan="3">
                                        <strong>
                                            {{ reservations|reduce((total, reservation) => 
                                                total + (reservation.nombrePlaces * (reservation.typePlace == 'VIP' ? 15 : 10)), 0) }} DT
                                        </strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div class="text-end mt-4">
                        <a href="{{ path('showallfilm') }}" class="btn btn-primary py-3 px-5">Continue Shopping</a>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</div>


<style>
