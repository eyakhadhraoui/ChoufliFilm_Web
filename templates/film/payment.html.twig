{% block body %}
<br><br><br><br>
<div class="container-xxl py-5">
    <div class="container">
        <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
            <h6 class="section-title text-center text-primary px-3">Payment</h6>
            <h1 class="mb-5">Complete Your Payment</h1>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-8">
                <div class="booking p-5">
                    <h2 class="text-white mb-4">Payment Summary</h2>
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="bg-dark bg-opacity-50 p-4 rounded">
                                <h4 class="text-white mb-4">Reservation Details</h4>
                                <div class="text-white mb-3">
                                    <strong>Movie:</strong> {{ reservation.titre }}
                                </div>
                                <div class="text-white mb-3">
                                    <strong>Cinema:</strong> {{ cinema }}
                                </div>
                                <div class="text-white mb-3">
                                    <strong>Date:</strong> {{ reservation.dateReservation|date('Y-m-d') }}
                                </div>
                                <div class="text-white mb-3">
                                    <strong>Seat Type:</strong> {{ reservation.typePlace }}
                                </div>
                                <div class="text-white mb-3">
                                    <strong>Number of Seats:</strong> {{ reservation.nombrePlaces }}
                                </div>
                                {% if reservation.selectedSeats %}
                                <div class="text-white mb-3">
                                    <strong>Selected Seats:</strong> 
                                    {% set seats = reservation.selectedSeats|replace({'[': '', ']': '', '"': ''})|split(',') %}
                                    {{ seats|join(', ') }}
                                </div>
                                {% endif %}
                                <div class="text-white mb-3">
                                    <strong>Association:</strong> {{ association }}
                                </div>
                                <div class="text-white mb-3">
                                    <strong>Total Amount:</strong> {{ total_amount }} DT
                                </div>
                            </div>
                        </div>
                        <form action="{{ path('app_payment_process', {'id': reservation.id}) }}" method="POST" class="mt-4">
                            <div class="row g-3">
                                <div class="col-12">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-transparent text-white" id="cardName" name="cardName" placeholder="Card Holder Name" required>
                                        <label for="cardName" class="text-white">Card Holder Name</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-transparent text-white" id="cardNumber" name="cardNumber" placeholder="Card Number" required>
                                        <label for="cardNumber" class="text-white">Card Number</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-transparent text-white" id="expiry" name="expiry" placeholder="MM/YY" required>
                                        <label for="expiry" class="text-white">Expiry Date (MM/YY)</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control bg-transparent text-white" id="cvv" name="cvv" placeholder="CVV" required>
                                        <label for="cvv" class="text-white">CVV</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100 py-3" type="submit">Pay Now</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.booking {
    background: linear-gradient(rgba(15, 23, 43, .7), rgba(15, 23, 43, .7)), url({{ asset('assets/back/img/cinema4.jpg') }});
    background-position: center center;
    background-repeat: no-repeat;
    background-size: cover;
    border-radius: 10px;
}

.form-floating > label {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    padding: 1rem .75rem;
    pointer-events: none;
    border: 1px solid transparent;
    transform-origin: 0 0;
    transition: opacity .1s ease-in-out,transform .1s ease-in-out;
}

.form-control.bg-transparent {
    background-color: rgba(255, 255, 255, 0.1) !important;
    border: 1px solid rgba(255, 255, 255, 0.3);
}

.form-control.bg-transparent:focus {
    background-color: rgba(255, 255, 255, 0.2) !important;
    border-color: #fff;
    box-shadow: none;
}

.form-floating>.form-control:focus~label,
.form-floating>.form-control:not(:placeholder-shown)~label {
    opacity: .65;
    transform: scale(.85) translateY(-0.5rem) translateX(0.15rem);
    color: #fff;
}

select.form-control option {
    background-color: #162A48;
    color: white;
}
