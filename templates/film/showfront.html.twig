 <!-- Package Start -->
    <div id="test5" class="container-xxl py-5">
        <div class="container">
            <div class="text-center wow fadeInUp" data-wow-delay="0.1s">
                <h6 class="section-title text-center text-primary px-3">Films</h6>
                <h1 class="mb-5">List of Films</h1>
            </div>
            <div class="row g-4 justify-content-center">
             {% for us in films %} 
                <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="package-item">
                        <div class="overflow-hidden">
                          
                            <img class="img-fluid2" src="{{ asset('uploads/' ~ us.getImageFilm()) }}" alt="Image" width="400" height="300px">
                        </div>
                        <div class="d-flex border-bottom">
                          &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
                            Durée :   &nbsp;&nbsp;  {{ us.getDuree() }} minutes 🕒
                       
                        </div>
                        <div class="text-center p-4">
                            <h3 class="mb-0">{{ us.getTitre() }}</h3>
                         
                            <p>{{ us.getDescription()}}</p>
                            <p>  Directeur :   &nbsp; {{us.getDirecteur()}} </p>
                           <p>    Note :   &nbsp; {{ us.getNote()}}</p>
                            <div class="d-flex justify-content-center mb-2">
                             
                                <a href="/user/front/{{us.id}}/deatilfront" class="btn btn-sm btn-primary px-3" style="border-radius: 0 30px 30px 0;">Show More</a>
                                &nbsp;&nbsp;
                          

                            </div>
                        </div>
                    </div>
                </div>
                 {% endfor %} 
              
                
            </div>
        </div>
    </div>
    <!-- Package End -->

   
 




