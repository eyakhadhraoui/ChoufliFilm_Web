<!-- Seat Selection Modal -->
<div id="seatModal" class="seat-modal">
    <div class="seat-modal-content">
        <span class="close" onclick="closeSeatModal()">&times;</span>
        <h4 class="text-center mb-4">Select Your Seats</h4>
        
        <div class="seat-legend">
            <div class="legend-item">
                <div class="legend-box legend-available"></div>
                <span>Available</span>
            </div>
            <div class="legend-item">
                <div class="legend-box legend-selected"></div>
                <span>Selected</span>
            </div>
            <div class="legend-item">
                <div class="legend-box legend-booked"></div>
                <span>Booked</span>
            </div>
        </div>

        <div class="screen">SCREEN</div>
        <div id="seatGrid" class="seat-grid">
            <!-- Seats will be generated here -->
        </div>
        <div class="mt-3 text-center">
            <strong>Selected Seats:</strong> <span id="modalSelectedSeatsDisplay"></span>
        </div>
        <div class="text-center">
            <button class="btn btn-primary mt-3" onclick="saveSelectedSeats()">Confirm Selection</button>
        </div>
    </div>
</div>

<!-- Add a hidden input for the film's end date -->
<input type="hidden" id="filmEndDate" value="{{ movie_details.date_fin|date('Y-m-d') }}">
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
let selectedSeats = new Set();
let bookedSeats = new Set();
let maxSeats = 1;
let refreshInterval;

// Update date validation to be non-intrusive
function isValidDate(dateStr) {
    const selected = new Date(dateStr);
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    return selected >= today;
}

function updateMaxSeats(value) {
    const numSeats = parseInt(value) || 0;
    maxSeats = numSeats;
    selectedSeats.clear();
    updateSelectedSeatsDisplay();
}

function handleNumberOfPlacesChange(value) {
    updateMaxSeats(value);
    if (validateSelectionRequirements()) {
        showSeats();
    }
}

function validateSelectionRequirements() {
    const dateInput = document.querySelector('#reservation_dateReservation');
    const salleSelect = document.querySelector('#reservation_salle');
    
    if (!dateInput.value) {
        alert('Please select a date first');
        dateInput.focus();
        return false;
    }
    
    if (!isValidDate(dateInput.value)) {
        alert('Please select a valid date');
        dateInput.focus();
        return false;
    }
    
    if (!salleSelect.value) {
        alert('Please select a cinema first');
        salleSelect.focus();
        return false;
    }
    
    return true;
}

function loadBookedSeats() {
    const salleSelect = document.querySelector('#reservation_salle');
    const dateInput = document.querySelector('#reservation_dateReservation');
    const salleId = salleSelect ? salleSelect.value : null;
    const date = dateInput ? dateInput.value : null;

    if (!salleId || !date) return;
    
    fetch(`/api/film/{{ movie_details.id }}/seats?date=${date}&salle=${salleId}`)
        .then(response => response.json())
        .then(data => {
            if (data.error) {
                alert(data.error);
                return;
            }
            
            bookedSeats = new Set(data.bookedSeats);
            updateSeatDisplay();
            
            // If any of our selected seats are now booked, deselect them
            selectedSeats.forEach(seatId => {
                if (bookedSeats.has(seatId)) {
                    selectedSeats.delete(seatId);
                }
            });
            updateSelectedSeatsDisplay();
        })
        .catch(error => {
            console.error('Error fetching booked seats:', error);
        });
}

function updateSeatDisplay() {
    document.querySelectorAll('.seat').forEach((seat, index) => {
        const seatNumber = index + 1;
        
        // Reset the seat's appearance
        seat.className = 'seat';
        seat.style.pointerEvents = 'auto';
        
        // Check if seat is booked
        if (bookedSeats.has(seatNumber)) {
            seat.classList.add('booked');
            seat.style.pointerEvents = 'none';
            seat.title = 'This seat is already booked';
        }
        
        // Check if seat is selected
        if (selectedSeats.has(seatNumber)) {
            seat.classList.add('selected');
        }
    });
}

function showSeats() {
    const modal = document.getElementById('seatModal');
    const seatGrid = document.getElementById('seatGrid');
    seatGrid.innerHTML = '';

    // Create and append seats
    for (let i = 1; i <= 50; i++) {
        const seat = document.createElement('div');
        seat.className = 'seat';
        seat.textContent = i;
        seat.onclick = () => toggleSeat(i);
        seatGrid.appendChild(seat);
    }

    modal.style.display = 'block';

    // Load initial booked seats
    loadBookedSeats();
    
    // Start periodic refresh of booked seats
    refreshInterval = setInterval(loadBookedSeats, 5000);
}

function toggleSeat(seatId) {
    if (bookedSeats.has(seatId)) {
        alert('This seat is already booked');
        return;
    }

    const seat = document.querySelector(`.seat:nth-child(${seatId})`);
    
    if (selectedSeats.has(seatId)) {
        selectedSeats.delete(seatId);
        seat.classList.remove('selected');
    } else if (selectedSeats.size < maxSeats) {
        selectedSeats.add(seatId);
        seat.classList.add('selected');
    } else {
        alert(`You can only select ${maxSeats} seat${maxSeats > 1 ? 's' : ''}`);
    }

    updateSelectedSeatsDisplay();
}

function updateSelectedSeatsDisplay() {
    const sortedSeats = Array.from(selectedSeats).sort((a, b) => a - b);
    document.getElementById('selectedSeatsDisplay').textContent = sortedSeats.join(', ');
    document.getElementById('modalSelectedSeatsDisplay').textContent = sortedSeats.join(', ');
    document.getElementById('selectedSeatsInput').value = JSON.stringify(sortedSeats);
}

function closeSeatModal() {
    document.getElementById('seatModal').style.display = 'none';
    // Clear the refresh interval when closing the modal
    if (refreshInterval) {
        clearInterval(refreshInterval);
        refreshInterval = null;
    }
}

function saveSelectedSeats() {
    if (selectedSeats.size === 0) {
        alert('Please select at least one seat');
        return;
    }
    
    if (selectedSeats.size !== maxSeats) {
        alert(`Please select exactly ${maxSeats} seat${maxSeats > 1 ? 's' : ''}`);
        return;
    }

    // Validate all required fields before closing
    const dateInput = document.querySelector('#reservation_dateReservation');
    const salleSelect = document.querySelector('#reservation_salle');
    const typePlace = document.querySelector('#reservation_type_Place');
    const association = document.querySelector('#reservation_association');

    if (!dateInput.value || !salleSelect.value || !typePlace.value || !association.value) {
        alert('Please fill in all required fields before confirming seats');
        return;
    }
    
    closeSeatModal();
}

// Add event listeners for date and cinema changes
document.addEventListener('DOMContentLoaded', function() {
    const nombrePlacesInput = document.querySelector('#reservation_nombre_places');
    const dateInput = document.querySelector('#reservation_dateReservation');
    const salleSelect = document.querySelector('#reservation_salle');
    
    if (nombrePlacesInput) {
        nombrePlacesInput.addEventListener('change', function() {
            handleNumberOfPlacesChange(this.value);
        });
        updateMaxSeats(nombrePlacesInput.value);
        nombrePlacesInput.setAttribute('min', '1');
        nombrePlacesInput.setAttribute('max', '10');
    }
    
    // Update booked seats when date changes
    if (dateInput) {
        dateInput.addEventListener('change', function() {
            if (this.value && isValidDate(this.value)) {
                if (selectedSeats.size > 0) {
                    if (confirm('Changing the date will clear your selected seats. Continue?')) {
                        selectedSeats.clear();
                        updateSelectedSeatsDisplay();
                    } else {
                        this.value = this.defaultValue;
                        return;
                    }
                }
                if (document.getElementById('seatModal').style.display === 'block') {
                    loadBookedSeats();
                }
            }
        });
    }
    
    // Update booked seats when cinema changes
    if (salleSelect) {
        salleSelect.addEventListener('change', function() {
            if (selectedSeats.size > 0) {
                if (confirm('Changing the cinema will clear your selected seats. Continue?')) {
                    selectedSeats.clear();
                    updateSelectedSeatsDisplay();
                } else {
                    this.value = this.defaultValue;
                    return;
                }
            }
            if (document.getElementById('seatModal').style.display === 'block') {
                loadBookedSeats();
            }
        });
    }

    // Start periodic refresh when modal is shown
    const modal = document.getElementById('seatModal');
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.target.style.display === 'block') {
                // Start periodic refresh
                refreshInterval = setInterval(loadBookedSeats, 5000);
            } else {
                // Clear interval when modal is hidden
                if (refreshInterval) {
                    clearInterval(refreshInterval);
                    refreshInterval = null;
                }
            }
        });
    });

    observer.observe(modal, { attributes: true, attributeFilter: ['style'] });
});

// Close modal when clicking outside
window.onclick = function(event) {
    const modal = document.getElementById('seatModal');
    if (event.target == modal) {
        closeSeatModal();
    }
}

    
</script>
