{% block stylesheets %}
{{ parent() }}
<style>
    .seat-modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
    }

    .seat-modal-content {
        background-color: #1a1e21;
        margin: 5% auto;
        padding: 20px;
        border: 1px solid #2c3034;
        border-radius: 8px;
        width: 90%;
        max-width: 800px;
        color: white;
    }

    .seat-grid {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 10px;
        margin: 20px auto;
        max-width: 600px;
        padding: 20px;
    }

    .seat {
        width: 40px;
        height: 40px;
        border: 2px solid #375a7f;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background-color: #2c3034;
        color: white;
        transition: all 0.3s;
        margin: 2px;
    }

    .seat:hover {
        background-color: #375a7f;
    }

    .seat.selected {
        background-color: #00bc8c;
        border-color: #00bc8c;
    }

    .seat.booked {
        background-color: #e74c3c;
        border-color: #e74c3c;
        cursor: not-allowed;
    }

    .screen {
        width: 80%;
        height: 30px;
        background: #375a7f;
        margin: 20px auto;
        border-radius: 5px;
        text-align: center;
        color: white;
        font-size: 14px;
        line-height: 30px;
        transform: perspective(300px) rotateX(-10deg);
        box-shadow: 0 3px 10px rgba(255,255,255,0.1);
    }

    .seat-legend {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin: 20px 0;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .legend-box {
        width: 20px;
        height: 20px;
        border-radius: 3px;
    }

    .legend-available {
        background-color: #2c3034;
        border: 2px solid #375a7f;
    }

    .legend-selected {
        background-color: #00bc8c;
        border: 2px solid #00bc8c;
    }

    .legend-booked {
        background-color: #e74c3c;
        border: 2px solid #e74c3c;
    }

    .close {
        color: #aaa;
        float: right;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .close:hover {
        color: white;
    }

    .booking {
        background: linear-gradient(rgba(15, 23, 43, .7), rgba(15, 23, 43, .7)), url({{ asset('assets/back/img/cinema4.jpg') }});
        background-position: center center;
        background-repeat: no-repeat;
        background-size: cover;
        border-radius: 10px;
    }

    .form-floating > label {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        padding: 1rem .75rem;
        pointer-events: none;
        border: 1px solid transparent;
        transform-origin: 0 0;
        transition: opacity .1s ease-in-out,transform .1s ease-in-out;
    }

    .form-control.bg-transparent {
        background-color: rgba(255, 255, 255, 0.1) !important;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .form-control.bg-transparent:focus {
        background-color: rgba(255, 255, 255, 0.2) !important;
        border-color: #fff;
        box-shadow: none;
    }

    .form-floating>.form-control:focus~label,
    .form-floating>.form-control:not(:placeholder-shown)~label {
        opacity: .65;
        transform: scale(.85) translateY(-0.5rem) translateX(0.15rem);
        color: #fff;
    }

    select.form-control option {
        background-color: #162A48;
        color: white;
    }

    .select-seats-btn {
        background-color: #375a7f;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .select-seats-btn:hover {
        background-color: #2c4a6f;
    }

    .selected-seats-display {
        margin-top: 10px;
        color: #00bc8c;
    }
</style>
{% endblock %}

