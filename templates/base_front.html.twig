/* Ajout d'effets 3D et modernisation du design */

/* Effet 3D pour les cartes */
.package-item {
    transform-style: preserve-3d;
    transition: transform 0.5s;
    perspective: 1000px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    border-radius: 15px;
    overflow: hidden;
}

.package-item:hover {
    transform: translateY(-10px) rotateX(5deg);
}

/* Effet de profondeur pour les images */
.img-fluid2 {
    transition: transform 0.5s;
    transform: scale(1);
}

.package-item:hover .img-fluid2 {
    transform: scale(1.1) translateZ(20px);
}

/* Modernisation des boutons */
.btn.btn-primary {
    background: linear-gradient(45deg, #007BFF, #00C6FF) !important;
    border: none !important;
    box-shadow: 0 4px 15px rgba(0,123,255,0.3);
    transition: all 0.3s ease;
    backdrop-filter: blur(5px);
}

.btn.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,123,255,0.4);
    background: linear-gradient(45deg, #00C6FF, #007BFF) !important;
}

/* Header moderne avec effet parallaxe */
.cinema-header {
    position: relative;
    overflow: hidden;
    transform-style: preserve-3d;
}

.cinema-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: inherit;
    transform: translateZ(-10px) scale(1.4);
    filter: blur(5px);
}

/* Navigation moderne avec effet glassmorphism */
.navbar {
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
}

/* Cards avec effet glassmorphism */
.team-item {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
}

.team-item:hover {
    transform: translateY(-10px) rotateY(5deg);
    box-shadow: 0 15px 30px rgba(0,0,0,0.2);
}

/* Effet de survol moderne pour les images */
.overflow-hidden {
    position: relative;
    overflow: hidden;
}

.overflow-hidden::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, rgba(0,123,255,0.2), rgba(0,198,255,0.2));
    opacity: 0;
    transition: opacity 0.3s;
}

.overflow-hidden:hover::after {
    opacity: 1;
}

/* Animation de rotation 3D pour le logo */
.test {
    animation: rotation3D 5s infinite linear;
    transform-style: preserve-3d;
}

@keyframes rotation3D {
    from {
        transform: rotate3d(1, 1, 1, 0deg);
    }
    to {
        transform: rotate3d(1, 1, 1, 360deg);
    }
}

/* Effet de profondeur pour les sections */
.container-xxl {
    perspective: 1000px;
}

.wow {
    transform-style: preserve-3d;
}

/* Ajout des styles pour le navbar dynamique */
.navbar {
    transition: transform 0.4s ease-in-out;
    position: fixed;
    width: 100%;
    top: 0;
    z-index: 1000;
}

.navbar-hidden {
    transform: translateY(-100%);
}

