    <style>
   .profile-container {
    position: relative;
    display: inline-block;
  }


 .profile-img2 {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px; /* Plus grand que l'image */
    height: 60px;
    border-radius: 50%;
    border: 5px solid blue; /* Fil bleu épais */
    box-sizing: border-box;
    transform: translate(-50%, -50%);
    pointer-events: none; /* Évite l'interaction */
}
  
  .profile-img3 {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 5px solid transparent; /* Bordure transparente */
    box-sizing: border-box;
    transform: translate(-50%, -50%);
    pointer-events: none;
    background: conic-gradient(blue 0deg 180deg, transparent 180deg 360deg);
}


  .profile-container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 3px solid transparent;
    border-top-color: blue; /* Création d'un petit fil bleu */
    transform: rotate(0deg);
  }
  
  .profile-img {
    display: block;
    width: 50px;
    height: 50px;
    border-radius: 50%;
  }
    .verified {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 18px;
    height: 18px;
    background-color: #0095f6;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 12px;
    font-weight: bold;
    border: 2px solid white;
  }
.dropdown-item:active {
    background-color: #162A48 !important;  /* Couleur de fond bleu */
    color: #007BFF !important;  /* Optionnel, pour que le texte soit blanc */
}

/* Change le fond en bleu quand l'utilisateur survole l'élément */
.dropdown-item:hover {
    background-color: #162A48 !important;  /* Couleur de fond bleu */
    color: #007BFF !important;  /* Texte blanc au survol */
} 
 .btn.btn-primary {
    background-color: var(--primary) !important; /* Couleur de fond bleu nuit */
    color: #FFFFFF !important;  /* Texte en blanc */
    border: 2px solid var(--primary) !important; /* Bordure bleu nuit */
    border-radius: 50px !important; /* Coins arrondis (pill) */
    padding: 10px 20px; /* Ajustez les valeurs de padding si nécessaire */
}

.btn.btn-primary:hover {
    background-color: #162A48 !important; /* Optionnel : change la couleur de fond au survol */
    border-color: #162A48 !important;  /* Change la bordure au survol */
}
.btn.btn-primary {
    background-color: #007BFF !important;  /* Bleu clair */
    color: #FFFFFF !important;  /* Texte en blanc */
    border: 2px solid #007BFF !important;  /* Bordure bleue */
    border-radius: 50px !important;  /* Coins arrondis (forme pilule) */
}

.btn.btn-primary:hover {
    background-color: #0056b3 !important;  /* Bleu plus foncé au survol */
    border-color
    : #0056b3 !important;  /* Bordure plus foncée au survol */
}
h1.text-primary {
    color: #007BFF !important;  /* Applique un bleu clair au texte du titre */
}

/* Applique également la couleur bleue aux icônes <i> à l'intérieur de <h1> avec .text-primary */
h1.text-primary i {
    color: #007BFF !important;  /* Applique un bleu clair à l'icône */
}

/* Si vous avez des images dans h1.text-primary, ne pas appliquer de filtre de couleur */
h1.text-primary img {
    filter: none !important;  /* Réinitialise tout filtre de couleur */
}
h6.text-primary {
    color: #007BFF !important;  /* Applique un bleu clair au texte */
}

/* Applique également la couleur bleue aux icônes <i> dans <h6> avec .text-primary */
h6.text-primary i {
    color: #007BFF !important;  /* Applique un bleu clair à l'icône */
}

/* Applique également la couleur bleue aux éléments avec .section-title ayant .text-primary */
h6.section-title.text-primary {
    color: #007BFF !important;  /* Applique un bleu clair au titre de section */
}
.icon-blue {
    color: #007BFF !important;  /* Bleu clair */
}
.rounded-circle {
    width: 60px;
    height: 6%;
    border-radius: 50%; /* Cela rend l'image circulaire */
    object-fit: cover;  /* Cela permet à l'image de garder une bonne proportion sans déformer l'image */
}

.arrow {
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-top: 10px solid #007BFF; /* Couleur de la flèche */
    margin-left: 8px;
    vertical-align: middle;
}

