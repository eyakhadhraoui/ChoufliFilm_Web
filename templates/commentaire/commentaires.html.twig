{% extends 'base.html.twig' %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<div class="container-fluid pt-4 px-4">
    <div class="bg-secondary text-center rounded p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h6 class="mb-0">Liste des Commentaires</h6>
            <a href="#">Afficher Tout</a>
        </div>

        <div class="table-responsive">
            <div class="container mt-4">
                <h2 class="text-center text-white">Liste des Commentaires</h2>

                <div class="table-container">
                    <table class="table table-dark table-hover">
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Prénom</th>
                                <th>Nom de l'Article</th>
                                <th>Contenu du Commentaire</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for commentaire in commentaires %}
                                <tr>
                                    <td>{{ commentaire.user.nom }}</td>
                                    <td>{{ commentaire.user.prenom }}</td>
                                    <td>{{ commentaire.article.titre }}</td>
                                    <td>{{ commentaire.contenuCom }}</td>
                                    <td>{{ commentaire.date|date('d/m/Y H:i') }}</td>
                                    <td>
                                        <a href="{{ path('comment_edit', {'id': commentaire.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                                        
                                  <td>
    <form action="{{ path('comment_delete', {'id': commentaire.id}) }}" method="POST" style="display:inline;" 
          onsubmit="return confirm('Voulez-vous vraiment supprimer ce commentaire ?');">
        {{ csrf_token('delete' ~ commentaire.id) | raw }}
        <button type="submit" class="btn btn-danger btn-sm">
            <i class="bi bi-trash-fill"></i> Supprimer
        </button>
    </form>
</td>

                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center">Aucun commentaire trouvé.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                <div class="pagination">
                    <ul class="pagination">
                        <li class="page-item {{ commentaires.getCurrentPageNumber() == 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('comment_list', { 'page': commentaires.getCurrentPageNumber() - 1 }) }}">Précédent</a>
                        </li>
                        {% for i in 1..commentaires.getPageCount() %}
                            <li class="page-item {{ commentaires.getCurrentPageNumber() == i ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('comment_list', { 'page': i }) }}">{{ i }}</a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ commentaires.getCurrentPageNumber() == commentaires.getPageCount() ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('comment_list', { 'page': commentaires.getCurrentPageNumber() + 1 }) }}">Suivant</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>    
{% endblock %}
