<style>
.google-container {
    width: 100%;
    max-width: 300px;
    margin: 20px auto;
    padding: 0 15px;
}

.google-btn {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    height: 45px;
    background: #1a1a1a;
    border-radius: 25px;
    text-decoration: none;
    border: 1px solid rgba(0, 255, 255, 0.2);
}

.google-circle {
    width: 35px;
    height: 35px;
    margin-left: 5px;
    background: #00ffff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
    color: #1a1a1a;
}

.google-text {
    margin-left: 15px;
    color: #00ffff;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.google-btn:hover {
    background: #2a2a2a;
    border-color: rgba(0, 255, 255, 0.3);
    box-shadow: 0 0 15px rgba(0, 255, 255, 0.2);
}

.google-btn:hover .google-circle {
    box-shadow: 0 0 10px rgba(0, 255, 255, 0.3);
}

.google-btn:active {
    transform: scale(0.98);
}
