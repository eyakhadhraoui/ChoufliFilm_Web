  <div class="signin"> 

    <div class="content"> 

     <h2>   Login Page</h2>   
     {% for message in app.flashes('error') %}
     <div style="color: red;">{{ message }}</div>
     {% endfor %}


 

<form method="post" action="{{ path('app_login') }}">
    <div class="form"> 
     {% if app.session.get('user_nom')%}
      il ya une session actuelle
      <div class="inputBox"> 
      <a href="{{ path('logout') }}">      <input type="eya" value="Logout"></a>
        </div> 

        <h2> Or </h2>
        
         {% if "ROLE_ADMIN" in app.session.get('roles')  %} 
           <div class="inputBox"> 
      <a href="{{ path('back') }}">      <input type="eya" value="Return To Page"></a>
        </div> 
        {% else  %}
          
           <div class="inputBox"> 
      <a href="{{ path('front') }}">      <input type="eya" value="Return To Page"></a>
        </div> 
        {% endif  %}
  {% else %}

        <div class="inputBox"> 
            <input type="email" name="email" id="email" class="form-control" autofocus placeholder="Email">
        </div>

        <div class="inputBox"> 
            <input type="password" name="password" id="password" class="form-control" autocomplete="current-password"  placeholder="Password">
        </div> 

        <div class="links"> 
            <a href="/user/resetpassword">Forgot Password</a> 
            <a href="{{ path('inscription') }}">Signup</a> 
        </div> 
        
        <div class="inputBox"> 
            <input type="submit" value="Login">
        </div> 

<div class="google-container">
    <a href="/connect/google" class="google-btn">
