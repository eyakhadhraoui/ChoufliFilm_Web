/* Animation de flottement */
@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}

.pagination {
    animation: float 4s ease-in-out infinite;
}

/* Container pour les boutons d'action */
.action-links-container {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin: 2rem 0;
    perspective: 1000px;
}

/* Style de base pour les boutons */
.show-all-btn, .trash-btn {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2rem;
    border-radius: 20px;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 1px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
}

/* Style spécifique pour Show All */
.show-all-btn {
    background: linear-gradient(135deg, #4facfe, #00f2fe);
    color: white;
    box-shadow: 
        0 10px 20px rgba(79,172,254,0.3),
        inset 0 0 20px rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.1);
}

/* Style spécifique pour Corbeille */
.trash-btn {
    background: linear-gradient(135deg, #ff6b6b, #ee5253);
    color: white;
    box-shadow: 
        0 10px 20px rgba(255,107,107,0.3),
        inset 0 0 20px rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.1);
}

/* Style des icônes */
.btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 35px;
    height: 35px;
    background: rgba(255,255,255,0.2);
    border-radius: 12px;
    transition: all 0.3s;
}

.btn-icon i {
    font-size: 1.3rem;
    color: white;
}

/* Texte des boutons */
.btn-text {
    font-size: 1.1rem;
    text-transform: uppercase;
    transform: translateZ(10px);
}

/* Effet de brillance */
.btn-shine {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
        45deg,
        transparent,
        rgba(255,255,255,0.3),
        transparent
    );
    transform: rotate(45deg);
    transition: 0.5s;
}

/* Effet de particules pour la corbeille */
.btn-particles {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, rgba(255,255,255,0.2) 10%, transparent 70%);
    opacity: 0;
    transition: opacity 0.3s;
}

/* Effets au survol */
.show-all-btn:hover, .trash-btn:hover {
    transform: translateY(-5px) rotateX(10deg);
}

.show-all-btn:hover {
    box-shadow: 
        0 15px 30px rgba(79,172,254,0.4),
        inset 0 0 30px rgba(255,255,255,0.3);
}

.trash-btn:hover {
    box-shadow: 
        0 15px 30px rgba(255,107,107,0.4),
        inset 0 0 30px rgba(255,255,255,0.3);
}

.show-all-btn:hover .btn-icon,
.trash-btn:hover .btn-icon {
    transform: scale(1.1) translateZ(20px);
    background: rgba(255,255,255,0.3);
}

.show-all-btn:hover .btn-shine,
.trash-btn:hover .btn-shine {
    animation: shine 1.5s infinite;
}

.trash-btn:hover .btn-particles {
    opacity: 1;
    animation: particles 2s linear infinite;
}

/* Animations */
@keyframes shine {
    0% {
        transform: rotate(45deg) translateX(-100%);
    }
    100% {
        transform: rotate(45deg) translateX(100%);
    }
}

@keyframes particles {
    0%, 100% {
        transform: scale(1);
        opacity: 0.2;
    }
    50% {
        transform: scale(1.1);
        opacity: 0.4;
    }
}

/* Animation au clic */
.show-all-btn:active,
.trash-btn:active {
    transform: scale(0.95);
}

/* Effet de pulsation */
@keyframes pulse {
    0%, 100% {
        transform: scale(1);
    }
    50% {
        transform: scale(1.05);
    }
}

.show-all-btn, .trash-btn {
    animation: pulse 3s infinite;
}

