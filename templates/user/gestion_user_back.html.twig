<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function () {
    let order = { nom: "asc", prenom: "asc" }; // Stocke l'état du tri pour chaque colonne

    function sortTable(columnIndex, columnName) {
        let rows = $("#myTable tbody tr").get(); // Récupère les lignes du tableau
        
        rows.sort(function (a, b) {
            let A = $(a).find(`td:nth-child(${columnIndex})`).text().toUpperCase(); 
            let B = $(b).find(`td:nth-child(${columnIndex})`).text().toUpperCase();

            if (order[columnName] === "asc") {
                return A.localeCompare(B); // Trie de A à Z
            } else {
                return B.localeCompare(A); // Trie de Z à A
            }
        });

        // Change l'ordre pour le prochain clic
        order[columnName] = order[columnName] === "asc" ? "desc" : "asc";

        // Réinsère les lignes triées dans le tableau
        $.each(rows, function (index, row) {
            $("#myTable tbody").append(row);
        });
    }

    // Événements de tri
    $("#myTable th:nth-child(1)").on("click", function () {
        sortTable(1, "nom");
    });

    $("#myTable th:nth-child(2)").on("click", function () {
        sortTable(2, "prenom");
    });
});
</script>



