.cosmic-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0A2647 0%, #144272 100%);
    perspective: 1000px;
    padding: 2rem;
}

.galaxy-background {
    position: relative;
    width: 100%;
    max-width: 600px;
}

.star-field {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    animation: twinkle 8s infinite;
}

.password-card {
    background: rgba(13, 28, 64, 0.8);
    backdrop-filter: blur(20px);
    border-radius: 20px;
    padding: 3rem;
    box-shadow: 
        0 0 30px rgba(255, 255, 255, 0.1),
        inset 0 0 20px rgba(0, 123, 255, 0.1);
    transform-style: preserve-3d;
    animation: floatCard 6s ease-in-out infinite;
    border: 1px solid rgba(255, 255, 255, 1);
    position: relative;
    overflow: hidden;
}

.password-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.3);
    pointer-events: none;
}

.holographic-effect {
    position: relative;
    z-index: 1;
}

.holographic-effect::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
        45deg,
        transparent,
        rgba(30, 144, 255, 0.1),
        transparent
    );
    transform: rotate(45deg);
    animation: holographicShine 6s linear infinite;
}

.cyber-title {
    color: #1E90FF;
    font-size: 2rem;
    text-align: center;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-shadow: 
        0 0 10px rgba(30, 144, 255, 0.5),
        0 0 20px rgba(30, 144, 255, 0.3),
        0 0 30px rgba(30, 144, 255, 0.1);
    transform: translateZ(30px);
}

.form-group-3d {
    margin-bottom: 2rem;
    transform-style: preserve-3d;
}

.input-wrapper {
    position: relative;
    transform-style: preserve-3d;
}

.cyber-label {
    color: #1E90FF;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    display: block;
    transform: translateZ(20px);
    text-shadow: 0 0 10px rgba(30, 144, 255, 0.3);
}

.cyber-input {
    width: 100%;
    padding: 1rem;
    background: rgba(10, 38, 71, 0.6);
    border: 1px solid rgba(30, 144, 255, 0.3);
    border-radius: 10px;
    color: #fff;
    font-size: 1rem;
    transition: all 0.3s ease;
    transform: translateZ(10px);
}

.cyber-input:focus {
    outline: none;
    border-color: #1E90FF;
    box-shadow: 
        0 0 20px rgba(30, 144, 255, 0.3),
        inset 0 0 10px rgba(30, 144, 255, 0.2);
    transform: translateZ(20px);
}

.input-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, #1E90FF, transparent);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.3s ease;
}

.cyber-input:focus + .input-line {
    transform: scaleX(1);
}

.cyber-button {
    width: 100%;
    padding: 1rem;
    background: linear-gradient(45deg, #0A2647, #1E90FF);
    border: none;
    border-radius: 10px;
    color: #fff;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transform: translateZ(20px);
    transition: all 0.3s ease;
}

.cyber-button:hover {
    background: linear-gradient(45deg, #1E90FF, #0A2647);
    box-shadow: 
        0 0 20px rgba(30, 144, 255, 0.3),
        inset 0 0 10px rgba(30, 144, 255, 0.2);
    transform: translateZ(30px);
}

.button-content {
    position: relative;
    z-index: 1;
}

.button-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
        45deg,
        transparent,
        rgba(30, 144, 255, 0.3),
        transparent
    );
    transform: rotate(45deg);
    animation: buttonGlow 3s linear infinite;
}

.error-message {
    color: #ff4444;
    background: rgba(255, 68, 68, 0.1);
    padding: 1rem;
    border-radius: 10px;
    margin-bottom: 1rem;
    border: 1px solid rgba(255, 68, 68, 0.3);
    animation: errorShake 0.5s ease-in-out;
    box-shadow: 0 0 15px rgba(255, 68, 68, 0.2);
}

@keyframes floatCard {
    0%, 100% {
        transform: translateZ(0) rotateX(0) rotateY(0);
        box-shadow: 
            0 0 30px rgba(255, 255, 255, 0.1),
            inset 0 0 20px rgba(0, 123, 255, 0.1);
    }
    25% {
        transform: translateZ(20px) rotateX(2deg) rotateY(-2deg);
        box-shadow: 
            0 0 40px rgba(255, 255, 255, 0.15),
            inset 0 0 30px rgba(0, 123, 255, 0.1);
    }
    75% {
        transform: translateZ(20px) rotateX(-2deg) rotateY(2deg);
        box-shadow: 
            0 0 40px rgba(255, 255, 255, 0.15),
            inset 0 0 30px rgba(0, 123, 255, 0.1);
    }
}

@keyframes holographicShine {
    0% {
        transform: translateX(-100%) rotate(45deg);
        background: linear-gradient(
            45deg,
            transparent,
            rgba(30, 144, 255, 0.1),
            transparent
        );
    }
    100% {
        transform: translateX(100%) rotate(45deg);
        background: linear-gradient(
            45deg,
            transparent,
            rgba(10, 38, 71, 0.1),
            transparent
        );
    }
}

@keyframes buttonGlow {
    0% {
        transform: translateX(-100%) rotate(45deg);
    }
    100% {
        transform: translateX(100%) rotate(45deg);
    }
}

@keyframes errorShake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
}

@keyframes twinkle {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
}

/* Responsive Design */
@media (max-width: 768px) {
    .password-card {
        padding: 2rem;
    }
    
    .cyber-title {
        font-size: 1.5rem;
    }
}

/* Ajout d'un effet de particules dorées */
.star-field::before,
.star-field::after {
    content: '';
    position: absolute;
    width: 3px;
    height: 3px;
    background: #1E90FF;
    border-radius: 50%;
    box-shadow: 
        0 0 10px #1E90FF,
        0 0 20px #1E90FF,
        0 0 30px #1E90FF;
    animation: starTwinkle 4s infinite;
}

@keyframes starTwinkle {
    0%, 100% {
        opacity: 0.3;
        transform: scale(1);
    }
    50% {
        opacity: 1;
        transform: scale(1.5);
    }
}
</style>
{% endblock %}

