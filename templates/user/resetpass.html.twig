{% block body %}
<br><br><br><br>
<div class="cosmic-container">
    <div class="galaxy-background">
        <div class="star-field"></div>
        <div class="password-card">
            <div class="holographic-effect">
                <h2 class="cyber-title">Modifier votre mot de passe</h2>
                {% for message in app.flashes('error') %}
                    <div class="error-message">{{ message }}</div>
                {% endfor %}
                <form method="post" action="{{ path('app_resetuserpassword') }}" class="neo-form">
                    <div class="form-group-3d">
                        <div class="input-wrapper">
                            <label for="oldpassword" class="cyber-label">Ancien mot de passe</label>
                            <input type="password" name="oldpassword" id="oldpassword" class="cyber-input" required>
                            <div class="input-line"></div>
                        </div>
                    </div>

                    <div class="form-group-3d">
                        <div class="input-wrapper">
                            <label for="newpassword" class="cyber-label">Nouveau mot de passe</label>
                            <input type="password" name="newpassword" id="newpassword" class="cyber-input" required>
                            <div class="input-line"></div>
                        </div>
                    </div>

                    <div class="form-group-3d">
                        <div class="input-wrapper">
                            <label for="confirmpassword" class="cyber-label">Confirmer nouveau mot de passe</label>
                            <input type="password" name="confirmpassword" id="confirmpassword" class="cyber-input" required>
                            <div class="input-line"></div>
                        </div>
                    </div>
                      <div class="form-group-3d">
                        <div class="input-wrapper">
                            <label for="code" class="cyber-label">Code Verfificaiton via SMS</label>
                            <input type="text" name="code" id="code" class="cyber-input" value={{code}} required>
                            <div class="input-line"></div>
                        </div>
                    </div>

                    <button type="submit" class="cyber-button">
                        <span class="button-content">Modifier le mot de passe</span>
                        <span class="button-glow"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

