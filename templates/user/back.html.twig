<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Données du graphique : Nombre de films sortis par mois
    const dataFilms = {
        labels: ["Jan", "Fév", "Mar", "Avr", "Mai", "Juin", "Juil", "Août", "Sep", "Oct", "Nov", "Déc"],
        datasets: [{
            label: "Nombre de films",
            data: [12, 18, 15, 22, 30, 25, 35, 28, 20, 26, 24, 30], // Valeurs fictives
            backgroundColor: ["#4169E1", "#1E3A8A"], // Bleu roi et bleu mer
            borderColor: "#1E3A8A",
            borderWidth: 2
        }]
    };

    // Configuration du graphique
    const configFilms = {
        type: "bar",
        data: dataFilms,
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true
                }
            }
        }
    };

    // Initialisation du graphique "Nombre de films"
    const ctxFilms = document.getElementById("salse-revenue").getContext("2d");
    new Chart(ctxFilms, configFilms);

    // Données du graphique : Top views (exemple simple)
    const dataTopViews = {
        labels: ["Jan", "Fév", "Mar", "Avr", "Mai", "Juin"],
        datasets: [{
            label: "Top views",
            data: [100, 150, 120, 180, 220, 170], // Valeurs fictives
              backgroundColor: "#1E3A8A", // Bleu marine
            borderColor: "#1E3A8A",     // Bleu marine (pour la bordure)
            borderWidth: 2
        }]
    };

    // Configuration du graphique "Top views"
    const configTopViews = {
        type: "line", // Exemple de graphique linéaire
        data: dataTopViews,
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true
                }
            }
        }
    };

    // Initialisation du graphique "Top views"
    const ctxTopViews = document.getElementById("worldwide-sales").getContext("2d");
    new Chart(ctxTopViews, configTopViews);
</script>

