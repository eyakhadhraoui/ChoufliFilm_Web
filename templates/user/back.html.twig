}

/* Cartes statistiques 3D */
.dashboard-card {
    perspective: 1500px;
    animation: floatIn 0.8s ease-out forwards;
    opacity: 0;
}

.dashboard-card:nth-child(1) { animation-delay: 0.1s; }
.dashboard-card:nth-child(2) { animation-delay: 0.2s; }
.dashboard-card:nth-child(3) { animation-delay: 0.3s; }
.dashboard-card:nth-child(4) { animation-delay: 0.4s; }

.dashboard-stats {
    background: linear-gradient(145deg, 
        rgba(11, 20, 55, 0.95), 
        rgba(27, 44, 95, 0.95)
    ) !important;
    border-radius: 20px !important;
    padding: 25px !important;
    transform-style: preserve-3d;
    transform: translateZ(20px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(64, 169, 255, 0.2);
    box-shadow: 
        0 20px 50px rgba(0, 0, 0, 0.5),
        0 0 40px rgba(64, 169, 255, 0.2) inset;
    position: relative;
    overflow: hidden;
}

/* Effet holographique avancé */
.dashboard-stats::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
        125deg,
        transparent 0%,
        rgba(64, 169, 255, 0.1) 50%,
        transparent 100%
    );
    transform: translateZ(50px);
    transition: all 0.6s ease;
    opacity: 0;
}

.dashboard-stats:hover::before {
    opacity: 1;
    animation: holographic 2s infinite linear;
}

/* Effet de survol 3D */
.dashboard-stats:hover {
    transform: translateY(-15px) rotateX(10deg) rotateY(5deg) translateZ(30px);
    box-shadow: 
        0 30px 60px rgba(0, 0, 0, 0.5),
        0 0 50px rgba(64, 169, 255, 0.3) inset;
}

/* Icônes 3D */
.dashboard-stats i {
    font-size: 2.5em;
    color: #40A9FF;
    filter: drop-shadow(0 0 15px rgba(64, 169, 255, 0.4));
    transition: all 0.6s ease;
    transform-style: preserve-3d;
    transform: translateZ(30px);
}

.dashboard-stats:hover i {
    transform: translateZ(50px) scale(1.2) rotate(10deg);
    color: #FFD700;
    filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.6));
}

/* Texte 3D */
.dashboard-stats .ms-3 {
    transform: translateZ(25px);
}

.dashboard-stats h6 {
    font-size: 1.4em;
    font-weight: bold;
    background: linear-gradient(45deg, #40A9FF, #FFD700);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
    transform: translateZ(40px);
}

/* Graphiques 3D */
.chart-container {
    transform-style: preserve-3d;
    transform: translateZ(0) rotateX(10deg);
    transition: all 0.6s ease;
    box-shadow: 
        0 20px 50px rgba(0, 0, 0, 0.4),
        0 0 40px rgba(64, 169, 255, 0.2) inset;
    border-radius: 30px;
    padding: 30px;
    background: linear-gradient(145deg, 
        rgba(11, 20, 55, 0.98), 
        rgba(27, 44, 95, 0.98)
    );
}

.chart-container:hover {
    transform: translateZ(30px) rotateX(5deg);
}

/* Animations */
@keyframes floatIn {
    0% {
        opacity: 0;
        transform: translateY(50px) translateZ(-100px);
    }
    100% {
        opacity: 1;
        transform: translateY(0) translateZ(0);
    }
}

@keyframes holographic {
    0% {
        opacity: 0;
        transform: translateX(-100%) translateZ(50px);
    }
    50% {
        opacity: 1;
    }
    100% {
        opacity: 0;
        transform: translateX(100%) translateZ(50px);
    }
}

/* Table 3D */
.table-container {
    transform-style: preserve-3d;
    perspective: 1000px;
    border-radius: 30px;
    overflow: hidden;
    background: linear-gradient(145deg, 
        rgba(11, 20, 55, 0.98), 
        rgba(27, 44, 95, 0.98)
    );
    box-shadow: 
        0 20px 50px rgba(0, 0, 0, 0.4),
        0 0 40px rgba(64, 169, 255, 0.2) inset;
}

.table-dark {
    transform: translateZ(20px);
}

.table-dark thead th {
    background: rgba(64, 169, 255, 0.1);
    color: #FFD700;
    font-weight: bold;
    transform: translateZ(30px);
}

.table-dark tbody tr {
    transition: all 0.4s ease;
    transform-style: preserve-3d;
}

.table-dark tbody tr:hover {
    transform: translateX(10px) translateZ(40px);
    background: rgba(64, 169, 255, 0.1);
    box-shadow: -10px 10px 20px rgba(0, 0, 0, 0.3);
}

/* Widgets 3D */
.widget-container {
    transform-style: preserve-3d;
    transform: translateZ(20px);
    transition: all 0.6s ease;
    border-radius: 25px;
    background: linear-gradient(145deg, 
        rgba(11, 20, 55, 0.98), 
        rgba(27, 44, 95, 0.98)
    );
    box-shadow: 
        0 20px 50px rgba(0, 0, 0, 0.4),
        0 0 40px rgba(64, 169, 255, 0.2) inset;
}

.widget-container:hover {
    transform: translateZ(40px) scale(1.02);
}
h2.text-center {
    font-size: 2.5rem;
    text-transform: uppercase;
    background: linear-gradient(45deg, #00f2fe, #4facfe);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    transform: translateZ(30px);
    animation: titleFloat 4s ease-in-out infinite;
}
</style>

 <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Fonction pour générer un tableau de couleurs dynamiques
    function generateColors(num) {
        var colors = [];
        var colorPalette = ['#3498DB', '#FFD700', '#FF6347', '#8E44AD', '#2ECC71', '#E74C3C', '#F39C12', '#1ABC9C', '#9B59B6', '#16A085'];
        for (var i = 0; i < num; i++) {
            colors.push(colorPalette[i % colorPalette.length]);
        }
        return colors;
    }

    var bannedCtx = document.getElementById('bannedChart').getContext('2d');
    var bannedChart;

    function updateBannedChart(type) {
        if (bannedChart) bannedChart.destroy();
        bannedChart = new Chart(bannedCtx, {
            type: type,
            data: {
                labels: {{ months|raw }},
                datasets: [{
                    label: 'Utilisateurs Bannis',
                    data: {{ counts1|raw }},
                    backgroundColor: generateColors({{ months|length }}),  // Génère des couleurs pour chaque mois
                    borderColor: '#3498DB',  // Bleu pour les bordures
                    borderWidth: 2,
                    fill: type === 'line' || type === 'doughnut'  // Remplissage pour ligne et doughnut
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                },
                maintainAspectRatio: false // Assure que l'aspect ratio est respecté pour les graphiques
            }
        });
    }

    updateBannedChart('line');

    var rolesCtx = document.getElementById('userRolesChart').getContext('2d');
    var userRolesChart;

    function updateRolesChart(type) {
        if (userRolesChart) userRolesChart.destroy();
        userRolesChart = new Chart(rolesCtx, {
            type: type,
            data: {
                labels: {{ roles|raw }},
                datasets: [{
                    label: 'Nombre d\'utilisateurs',
                    data: {{ counts|raw }},
                    backgroundColor: generateColors({{ roles|length }}),  // Génère des couleurs pour chaque rôle
                    borderColor: '#3498DB',  // Bleu pour les bordures
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                },
                maintainAspectRatio: false // Assure que l'aspect ratio est respecté pour les graphiques
            }
        });
    }

    updateRolesChart('line');
</script>
{% endblock %}

