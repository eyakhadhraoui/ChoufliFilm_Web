<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Fonction pour générer un tableau de couleurs dynamiques
    function generateColors(num) {
        var colors = [];
        var colorPalette = ['#3498DB', '#FFD700', '#FF6347', '#8E44AD', '#2ECC71', '#E74C3C', '#F39C12', '#1ABC9C', '#9B59B6', '#16A085'];
        for (var i = 0; i < num; i++) {
            colors.push(colorPalette[i % colorPalette.length]);
        }
        return colors;
    }

    var reclamationsCtx = document.getElementById('reclamationsChart').getContext('2d');
    var reclamationsByTypeCtx = document.getElementById('reclamationsByTypeChart').getContext('2d');
    var reclamationsChart;
    var reclamationsByTypeChart;

    // Fonction pour mettre à jour les graphiques de réclamations (par statut ou par type)
    function updateReclamationsChart(attribute, type) {
        if (attribute === 'status') {
            if (reclamationsChart) reclamationsChart.destroy();
            // Graphique des réclamations par statut
            reclamationsChart = new Chart(reclamationsCtx, {
                type: type,
                data: {
                    labels: {{ statuses|raw }}, // Labels dynamiques pour les statuts
                    datasets: [{
                        label: 'Réclamations par Statut',
                        data: {{ reclamationCounts|raw }}, // Données dynamiques pour les réclamations
                        backgroundColor: generateColors({{ statuses|length }}),  // Génère des couleurs pour chaque statut
                        borderColor: '#3498DB',  // Bleu pour les bordures
                        borderWidth: 2,
                        fill: type === 'line' || type === 'doughnut'  // Remplissage pour ligne et doughnut
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'top',
                        },
                    },
                    maintainAspectRatio: false
                }
            });
        } else if (attribute === 'type') {
            if (reclamationsByTypeChart) reclamationsByTypeChart.destroy();
            // Graphique des réclamations par type
            reclamationsByTypeChart = new Chart(reclamationsByTypeCtx, {
                type: type,
                data: {
                    labels: {{ types|raw }}, // Labels dynamiques pour les types
                    datasets: [{
                        label: 'Réclamations par Type',
                        data: {{ reclamationCountsByType|raw }}, // Données dynamiques pour les types de réclamations
                        backgroundColor: generateColors({{ types|length }}),  // Génère des couleurs pour chaque type
                        borderColor: '#3498DB',  // Bleu pour les bordures
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'top',
                        },
                    },
                    maintainAspectRatio: false
                }
            });
        }
    }

    // Initialisation des graphiques avec le type 'line' par défaut
    updateReclamationsChart('status', 'line');
    updateReclamationsChart('type', 'line');
</script>


