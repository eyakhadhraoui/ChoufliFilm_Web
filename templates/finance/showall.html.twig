{% extends 'base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<style>
    .seat-modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.5);
    }

    .seat-modal-content {
        background-color: #1a1e21;
        margin: 15% auto;
        padding: 20px;
        border: 1px solid #2c3034;
        border-radius: 8px;
        width: 80%;
        max-width: 600px;
        color: white;
    }

    .seat-grid {
        display: grid;
        grid-template-columns: repeat(10, 1fr);
        gap: 10px;
        margin: 20px 0;
    }

    .seat {
        width: 30px;
        height: 30px;
        border: 2px solid #375a7f;
        border-radius: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background-color: #2c3034;
        color: white;
        transition: all 0.3s;
    }

    .seat:hover {
        background-color: #375a7f;
    }

    .seat.selected {
        background-color: #00bc8c;
        border-color: #00bc8c;
    }

    .seat.booked {
        background-color: #e74c3c;
        border-color: #e74c3c;
        cursor: not-allowed;
    }

    .screen {
        width: 100%;
        height: 20px;
        background: #375a7f;
        margin: 20px 0;
        border-radius: 5px;
        text-align: center;
        color: white;
        font-size: 12px;
        line-height: 20px;
    }

    .close {
        color: #aaa;
        float: right;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .close:hover {
        color: white;
    }

    .seats-info {
        color: #00bc8c;
        cursor: pointer;
    }

    .seats-info:hover {
        text-decoration: underline;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid pt-4 px-4">
    <div class="bg-secondary rounded h-100 p-4">
        <h6 class="mb-4">All Reservations</h6>
        <div class="table-container">
            <table class="table table-dark">
                <thead>
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">User</th>
                        <th scope="col">Film</th>
                        <th scope="col">Cinema</th>
                        <th scope="col">Date</th>
                        <th scope="col">Places</th>
                        <th scope="col">Seats</th>
                        <th scope="col">Status</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reservation in reservations %}
                    <tr>
                        <td>{{ reservation.id }}</td>
                        <td>{{ reservation.user.nom }} {{ reservation.user.prenom }}</td>
                        <td>{{ reservation.titre }}</td>
                        <td>{{ reservation.salle ? reservation.salle.nomSalle : 'N/A' }}</td>
                        <td>{{ reservation.dateReservation|date('Y-m-d') }}</td>
                        <td>{{ reservation.nombrePlaces }}</td>
                        <td>
                            {% if reservation.selectedSeats %}
                                {% set seats = reservation.selectedSeats|replace({'[': '', ']': '', '"': ''})|split(',') %}
                                {{ seats|join(', ') }}
                            {% else %}
                                No seats selected
                            {% endif %}
                        </td>
                        <td class="{% if reservation.status == 'Confirmed' %}status-visible{% else %}status-hidden{% endif %}">
                            {{ reservation.status }}
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="{{ path('app_reservation_delete', {'id': reservation.id}) }}" class="action-btn trash" 
                                   onclick="return confirm('Are you sure you want to delete this reservation?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Seat Selection Modal -->
<div id="seatModal" class="seat-modal">
    <div class="seat-modal-content">
        <span class="close" onclick="closeSeatModal()">&times;</span>
        <h4>Select Seats</h4>
        <div class="screen">SCREEN</div>
        <div id="seatGrid" class="seat-grid">
            <!-- Seats will be generated here -->
        </div>
        <div class="mt-3">
            <strong>Selected Seats:</strong> <span id="selectedSeatsDisplay"></span>
        </div>
        <button class="btn btn-primary mt-3" onclick="saveSelectedSeats()">Save Selection</button>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
let currentReservationId = null;
let selectedSeats = new Set();
let bookedSeats = new Set();

function showSeats(reservationId, numberOfPlaces) {
    currentReservationId = reservationId;
    const modal = document.getElementById('seatModal');
    const seatGrid = document.getElementById('seatGrid');
    seatGrid.innerHTML = '';
    selectedSeats.clear();

    // Fetch booked seats for this reservation
    fetch(`/api/reservation/${reservationId}/seats`)
        .then(response => response.json())
        .then(data => {
            bookedSeats = new Set(data.bookedSeats);
            
            // Generate seats
            for (let i = 1; i <= 50; i++) {
                const seat = document.createElement('div');
                seat.className = `seat ${bookedSeats.has(i) ? 'booked' : ''}`;
                seat.textContent = i;
                seat.onclick = () => toggleSeat(i, numberOfPlaces);
                seatGrid.appendChild(seat);
            }
        });

    modal.style.display = 'block';
}

function toggleSeat(seatId, maxSeats) {
    if (bookedSeats.has(seatId)) return;

    const seat = document.querySelector(`.seat:nth-child(${seatId})`);
    
    if (selectedSeats.has(seatId)) {
        selectedSeats.delete(seatId);
        seat.classList.remove('selected');
    } else if (selectedSeats.size < maxSeats) {
        selectedSeats.add(seatId);
        seat.classList.add('selected');
    }

    updateSelectedSeatsDisplay();
}

function updateSelectedSeatsDisplay() {
    const display = document.getElementById('selectedSeatsDisplay');
    display.textContent = Array.from(selectedSeats).sort((a, b) => a - b).join(', ');
}

function closeSeatModal() {
    document.getElementById('seatModal').style.display = 'none';
}

function saveSelectedSeats() {
    if (currentReservationId && selectedSeats.size > 0) {
        fetch(`/api/reservation/${currentReservationId}/seats`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                seats: Array.from(selectedSeats)
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                closeSeatModal();
                // Optionally refresh the page or update the UI
                location.reload();
            }
        });
    }
}

// Close modal when clicking outside
window.onclick = function(event) {
    const modal = document.getElementById('seatModal');
    if (event.target == modal) {
        closeSeatModal();
    }
}
</script>
{% endblock %} 