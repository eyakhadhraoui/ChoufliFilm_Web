{% extends 'base.html.twig' %}

{% block body %}






    <div class="table-container">
      
      <div class="d-flex align-items-center justify-content-between mb-4">
     
     
 
                      
                    </div>

 <h2 class="text-center text-white">Liste des Ressources Pour Association {{ aso.getNom()}}</h2>
 <br>
<br>    

<table class="table table-dark table-hover">
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Prenom</th>
                    <th>Email</th>
                    <th>Nom Association</th>
                    <th>Image Association</th>
                      <th>Image User</th>
                     <th>Besoin_Spécifique</th>
                  
                 
                </tr>
                {% for us in ressource %}
<tr>

<td>{{ us.getUserNom() }}</td>
<td>{{ us. getUserPrenom()}}</td>
<td>
{{ us.getUserEmail() }}</td>
<td>
{{ us.getAssociation().getNom() }}</td>
<td>
<img class="rounded-circle1 me-lg-2" src="{{ asset('uploads/' ~ us.getAssociation().getImage()) }}" alt="Image" >

</td>

<td>
<img class="rounded-circle1 me-lg-2" src="{{ asset('uploads/' ~ us.getUser().getImage()) }}" alt="Image" >

</td>
<td>
{{ us.getBesoinSpecifique() }}</td>

</tr>

{% endfor %}
</table>

  







    </div>


<br>

<style>
.rounded-circle1 {
    width:50px;
    height: 6%;
    border-radius: 50%; 
    object-fit: cover;  
}




</style>
{% endblock %}