</style>
<div class="blog-container">
    <h1>Decouvrir Articles</h1>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <a href="{{ path('blogs') }}" class="{{ selectedCategorie is not defined or selectedCategorie is empty ? 'active' : '' }}">All</a>
        <a href="{{ path('blogs', {'categorie': 'film'}) }}" class="{{ selectedCategorie == 'film' ? 'active' : '' }}">Film</a>
        <a href="{{ path('blogs', {'categorie': 'cinema'}) }}" class="{{ selectedCategorie == 'cinema' ? 'active' : '' }}">Cinéma</a>
        <a href="{{ path('blogs', {'categorie': 'snacks'}) }}" class="{{ selectedCategorie == 'snacks' ? 'active' : '' }}">Snacks</a>
        <a href="{{ path('blogs', {'categorie': 'acteurs'}) }}" class="{{ selectedCategorie == 'acteurs' ? 'active' : '' }}">Acteurs</a>
        <a href="{{ path('blogs', {'categorie': 'autre'}) }}" class="{{ selectedCategorie == 'autre' ? 'active' : '' }}">Autre</a>
    </div>

    <!-- Articles Grid -->
    <div class="articles-container">
        {% for article in pagination %}
            <div class="article-card">
                <div class="article-image">
                   <img src="{{ asset('uploads/articles/' ~ article.image) }}" alt="{{ article.titre }}" width="100">
                </div>
                <div class="article-content">
                    <h2>{{ article.titre }}</h2>
                    <p class="pub-date">Published on: {{ article.datePublication|date('d/m/Y') }}</p>
                    <a href="{{ path('article_detail', {'id': article.id}) }}" class="read-more">voir plus</a>
                </div>
            </div>
        {% else %}
            <p style="text-align: center; color: #777;">No articles found</p>
        {% endfor %}
    </div>

    <!-- Pagination -->
    <div class="pagination" style="text-align: center;">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>
{% endblock %}