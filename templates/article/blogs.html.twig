<style>
    /* General styling */
    body {
        font-family: 'Poppins', sans-serif;
        background-color: #f5f5f5;
    }

    /* Blog container */
    .blog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .blog-container h1 {
        text-align: center;
        margin-bottom: 40px;
        font-size: 2.5rem;
        color: #333;
    }

    /* Filter bar */
    .filter-bar {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .filter-bar a {
        padding: 10px 20px;
        background: #3498db;
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    }

    .filter-bar a:hover, .filter-bar a.active {
        background: #217dbb;
        transform: translateY(-2px);
    }

    /* Articles grid */
    .articles-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 20px;
        padding: 20px;
    }

    .article-card {
        border-radius: 15px;
        overflow: hidden;
        background: white;
        box-shadow: 0px 4px 8px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .article-card:hover {
        transform: translateY(-5px);
        box-shadow: 0px 6px 12px rgba(0, 0, 0, 0.15);
    }

    /* Image */
    .article-image img {
        width: 100%;
        height: 220px;
        object-fit: cover;
        border-top-left-radius: 15px;
        border-top-right-radius: 15px;
    }

    /* Article content */
    .article-content {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .article-content h2 {
        margin-bottom: 10px;
        font-size: 1.5rem;
        color: #333;
    }

    .pub-date {
        color: #777;
        font-size: 0.9rem;
        margin-bottom: 15px;
    }

    /* Read more button */
    .read-more {
        margin-top: auto;
        text-align: center;
        display: block;
        padding: 12px;
        background: #3498db;
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        transition: background 0.3s ease;
    }

    .read-more:hover {
        background: #217dbb;
    }

        .nav-item.nav-link[href="{{ path('logout') }}"] {
